[core]
  whitespace = cr-at-eol
  pager = LESS=-qFR less
  quotepath = false
  editor = vim
[color]
  ui = auto
[alias]
  s  = status --short --branch
  st = status
  br = branch
  co = checkout
  ci = commit
  d  = diff
  dc = diff --cached
  f  = fetch
  fa = fetch --all
  sw = switch
[include]
  path = ~/.gitconfig.local
[pager]
  log  = diff-highlight | less
  show = diff-highlight | less
  diff = diff-highlight | less
[diff "minjs"]
  textconv = js-beautify
[diff "xlsx"]
  binary = true
  textconv = $GOPATH/bin/git-xlsx-textconv
[diff]
  compactionHeuristic = true
[fetch]
  prune = true
[user]
  useConfigOnly = true
  name = castor4bit
  email = castor.4bit@gmail.com
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHXBk1CBzLm7I7u6r3M4n0MiayU5jJSj4edpijWw0cl1
[init]
  defaultBranch = main
[gpg]
  format = ssh
[gpg "ssh"]
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
  gpgsign = true
